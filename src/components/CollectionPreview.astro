---
import EntryList from "./EntryList.astro";
import LinkButton from "./LinkButton.astro";

type ItemLink = {
  href: string;
  label: string;
};

type Item = {
  href: string;
  title: string;
  description: string;
  eyebrow?: string;
  badges?: string[];
  links?: ItemLink[];
};

type Props = {
  title: string;
  description: string;
  href: string;
  linkLabel: string;
  items: Item[];
};

const { title, description, href, linkLabel, items } = Astro.props;
---

<section class="py-8 first:pt-10">
  <div
    class="mb-5 flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between"
  >
    <div>
      <h2 class="text-2xl font-semibold tracking-wide">{title}</h2>
      <p class="mt-2 max-w-2xl text-foreground/80">{description}</p>
    </div>
    <LinkButton href={href}>{linkLabel}</LinkButton>
  </div>
  <EntryList items={items} />
</section>
