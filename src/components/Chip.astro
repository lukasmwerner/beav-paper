---
import type { HTMLAttributes } from "astro/types";

type Props = {
  label: string;
} & HTMLAttributes<"span">;

const { label, class: className, ...attrs } = Astro.props;
---

<span
  class:list={[
    "inline-flex items-center rounded-full border border-border bg-muted px-3 py-1 text-sm text-foreground/85",
    className,
  ]}
  {...attrs}
>
  {label}
</span>
