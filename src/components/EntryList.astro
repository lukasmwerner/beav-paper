---
import LinkButton from "./LinkButton.astro";
import Chip from "./Chip.astro";

type ItemLink = {
  href: string;
  label: string;
};

type Item = {
  href: string;
  title: string;
  description: string;
  eyebrow?: string;
  badges?: string[];
  links?: ItemLink[];
};

type Props = {
  items: Item[];
  emptyMessage?: string;
};

const { items, emptyMessage = "Nothing here yet." } = Astro.props;
---

{
  items.length > 0 ? (
    <ul class="space-y-6">
      {items.map(item => (
        <li class="rounded-2xl border border-border bg-background/80 p-5 shadow-xs shadow-black/5">
          {item.eyebrow && (
            <p class="mb-2 text-sm font-medium tracking-wide text-accent uppercase">
              {item.eyebrow}
            </p>
          )}
          <a
            href={item.href}
            class="inline-block text-xl font-semibold text-accent decoration-dashed underline-offset-4 hover:underline"
          >
            {item.title}
          </a>
          <p class="mt-3 text-foreground/85">{item.description}</p>

          {item.badges && item.badges.length > 0 && (
            <div class="mt-4 flex flex-wrap gap-2">
              {item.badges.map(label => <Chip {label} />)}
            </div>
          )}

          {item.links && item.links.length > 0 && (
            <div class="mt-5 flex flex-wrap gap-3">
              {item.links.map(link => (
                <LinkButton href={link.href}>{link.label}</LinkButton>
              ))}
            </div>
          )}
        </li>
      ))}
    </ul>
  ) : (
    <p>{emptyMessage}</p>
  )
}
