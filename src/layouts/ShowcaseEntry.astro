---
import { render, type CollectionEntry } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import BackButton from "@/components/BackButton.astro";
import BackToTopButton from "@/components/BackToTopButton.astro";
import Datetime from "@/components/Datetime.astro";
import LinkButton from "@/components/LinkButton.astro";
import Chip from "@/components/Chip.astro";
import { SITE } from "@/config";

type Entry = CollectionEntry<"projects">;

type Props = {
  entry: Entry;
  sectionLabel: string;
};

const { entry, sectionLabel } = Astro.props;
const { Content } = await render(entry);

const {
  title,
  description,
  ogImage: initOgImage,
  canonicalURL,
  pubDatetime,
  modDatetime,
  tags,
} = entry.data;

let ogImage: string | undefined;

if (typeof initOgImage === "string") {
  ogImage = initOgImage;
} else if (initOgImage?.src) {
  ogImage = new URL(initOgImage.src, Astro.url.origin).href;
}

const actions = [
  "repoUrl" in entry.data && entry.data.repoUrl
    ? { href: entry.data.repoUrl, label: "Repository" }
    : null,
  "demoUrl" in entry.data && entry.data.demoUrl
    ? { href: entry.data.demoUrl, label: "Live demo" }
    : null,
].filter(
  (action): action is { href: string; label: string } => action !== null
);

const chips = [
  "status" in entry.data && entry.data.status ? entry.data.status : null,
  ...(tags ?? []),
  ...("stack" in entry.data ? entry.data.stack : []),
].filter(Boolean);

const fallbackBackUrl = "/projects";
---

<Layout
  title={`${title} | ${SITE.title}`}
  description={description}
  canonicalURL={canonicalURL}
  ogImage={ogImage}
  pubDatetime={pubDatetime}
  modDatetime={modDatetime}
>
  <Header />
  <BackButton />
  <main
    id="main-content"
    data-back-url={fallbackBackUrl}
    data-pagefind-body
    class:list={["app-layout pb-12", { "mt-8": !SITE.showBackButton }]}
  >
    <p class="text-sm font-semibold tracking-[0.2em] text-accent uppercase">
      {sectionLabel}
    </p>
    <h1 class="mt-3 text-3xl font-bold tracking-tight sm:text-4xl">{title}</h1>
    <p class="mt-4 max-w-3xl text-lg text-foreground/85">{description}</p>

    {
      pubDatetime && (
        <Datetime
          class="mt-4"
          pubDatetime={pubDatetime}
          modDatetime={modDatetime}
          size="lg"
        />
      )
    }

    {
      chips.length > 0 && (
        <div class="mt-5 flex flex-wrap gap-2">
          {chips.map(label => (
            <Chip label={String(label)} />
          ))}
        </div>
      )
    }

    {
      actions.length > 0 && (
        <div class="mt-6 flex flex-wrap gap-3">
          {actions.map(action => (
            <LinkButton href={action.href}>{action.label}</LinkButton>
          ))}
        </div>
      )
    }

    <article class="app-prose mt-10 max-w-app">
      <Content />
    </article>

    <BackToTopButton />
  </main>
  <Footer />
</Layout>

<script>
  function syncBackUrl() {
    const mainContent = document.querySelector("#main-content");
    const fallbackBackUrl = mainContent?.getAttribute("data-back-url") || "/";
    const currentBackUrl = sessionStorage.getItem("backUrl");
    const allowedPrefixes = ["/projects", "/search", "/"];

    const isAllowed =
      !!currentBackUrl &&
      allowedPrefixes.some(prefix =>
        prefix === "/"
          ? currentBackUrl === "/"
          : currentBackUrl.startsWith(prefix)
      );

    if (!isAllowed) {
      sessionStorage.setItem("backUrl", fallbackBackUrl);
    }
  }

  syncBackUrl();
  document.addEventListener("astro:page-load", syncBackUrl);
</script>
